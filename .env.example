# ─────────────────────────────────────────────────────────────────────────────
# Zoho Bookkeeper MCP Server — Environment Variables
# Copy this file to .env for local development (never commit .env)
# In Railway: add these directly in the Variables tab
# ─────────────────────────────────────────────────────────────────────────────

# ── Security (REQUIRED in production) ────────────────────────────────────────
# Generate with: openssl rand -hex 32
# Add as Authorization: Bearer <value> in your Claude.ai connector header
MCP_API_KEY=your-strong-random-api-key-here

# ── Server config (optional — Railway sets PORT automatically) ────────────────
PORT=8004
HOST=0.0.0.0


# ══════════════════════════════════════════════════════════════════════════════
# OPTION A: Multi-client mode (recommended for CA firms with multiple clients)
# Add one block per client company. Replace SLUG with a short uppercase name.
# SLUG can be: FLUTCH, ACOUSTIC, CLIENTA, etc. — alphanumeric + underscores only
# ══════════════════════════════════════════════════════════════════════════════

# ── Client 1 ─────────────────────────────────────────────────────────────────
# Get CLIENT_ID and CLIENT_SECRET from: https://api-console.zoho.in/
# (Self Client → Create → ZohoBooks.fullaccess.all scope)
CLIENT_FLUTCH_NAME=Flutch Technology Pvt Ltd
CLIENT_FLUTCH_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_FLUTCH_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_FLUTCH_REFRESH_TOKEN=1000.xxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_FLUTCH_ORG_ID=60018950074
# India datacenter (use https://www.zohoapis.com/books/v3 for US/global)
CLIENT_FLUTCH_API_URL=https://www.zohoapis.in/books/v3

# ── Client 2 ─────────────────────────────────────────────────────────────────
CLIENT_ACOUSTIC_NAME=Acoustic Interio Solutions
CLIENT_ACOUSTIC_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_ACOUSTIC_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_ACOUSTIC_REFRESH_TOKEN=1000.xxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLIENT_ACOUSTIC_ORG_ID=60041513897
CLIENT_ACOUSTIC_API_URL=https://www.zohoapis.in/books/v3

# ── Add more clients following the same pattern ───────────────────────────────
# CLIENT_<SLUG>_NAME=Company Name
# CLIENT_<SLUG>_CLIENT_ID=1000.xxx
# CLIENT_<SLUG>_CLIENT_SECRET=xxx
# CLIENT_<SLUG>_REFRESH_TOKEN=1000.xxx
# CLIENT_<SLUG>_ORG_ID=60xxxxxxxxx
# CLIENT_<SLUG>_API_URL=https://www.zohoapis.in/books/v3


# ══════════════════════════════════════════════════════════════════════════════
# OPTION B: Single-client mode (backward compatible — use if you have ONE org)
# If CLIENT_* vars above are set, these are ignored.
# ══════════════════════════════════════════════════════════════════════════════
# ZOHO_CLIENT_NAME=My Company Name
# ZOHO_CLIENT_ID=1000.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_REFRESH_TOKEN=1000.xxxxxxxx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ZOHO_ORGANIZATION_ID=60xxxxxxxxx
# ZOHO_API_URL=https://www.zohoapis.in/books/v3


# ══════════════════════════════════════════════════════════════════════════════
# HOW TO GET ZOHO CREDENTIALS
# ══════════════════════════════════════════════════════════════════════════════
#
# Step 1 — Create a Self Client app (one per client company):
#   → https://api-console.zoho.in/
#   → Add Client → Self Client
#   → Scope: ZohoBooks.fullaccess.all,ZohoBooks.bankaccounts.ALL,ZohoBooks.transactions.ALL
#   → Copy CLIENT_ID and CLIENT_SECRET
#
# Step 2 — Generate Refresh Token for that client:
#   → In Self Client → Generate Code → Scope (same as above) → Duration: Permanent
#   → Copy the grant code
#   → Exchange for refresh token:
#
#   curl -X POST https://accounts.zoho.in/oauth/v2/token \
#     -d "grant_type=authorization_code" \
#     -d "client_id=YOUR_CLIENT_ID" \
#     -d "client_secret=YOUR_CLIENT_SECRET" \
#     -d "redirect_uri=https://www.zoho.com/books" \
#     -d "code=YOUR_GRANT_CODE"
#
#   → Copy "refresh_token" from the JSON response
#
# Step 3 — Get Org ID:
#   → Zoho Books → Settings → Organization Profile → Organization ID
#   → Or call list_organizations via MCP after configuring credentials
#
# Step 4 — Enter all values in Railway Variables tab → Redeploy
